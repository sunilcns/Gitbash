Clone : to download the files and folder to local 
	git clone https://github.com/sunilcns/AI-Devops.git 


	1.  Clone your repo
	git clone https://github.com/sunilcns/AI-Devops.git

		# Navigate into it
		cd AI-Devops
		
		# Check current status
		git status


	2. Add files 
	# Add a single file
	git add README.md
	
	# Add all files in a folder
	git add demos/
	
	# Add all changed files at once
	git add .
	
	# Add specific file type
	git add *.md
	
	# Verify what is staged
	git status
	
	3. COMMIT Changes 
		# Commit with a message
		git commit -m "Add new demo scripts"
		
		# Add and commit in one step
		git commit -am "Update existing files"
		
		# Commit with detailed message
		git commit -m "feat: add kubernetes demo
		
		- Added deployment.yaml
		- Added debug-pod.sh
		- Added README for demo"
		
	4. Push to Github 
		# Push to main branch
		git push origin main
		
		# Push to a specific branch
		git push origin feature/my-branch
		
		# First time push (set upstream)
		git push -u origin main
		
	5. Pull latest changes 
		# Pull latest from main
		git pull origin main
		
		# Pull and rebase
		git pull --rebase origin main
		
	6. Create a moify files 
		# Create a new file
		touch demos/01-local-llm/README.md
		
		# Create nested directories
		mkdir -p demos/06-new-demo/scripts
		
		# Edit a file (opens in default editor)
		nano README.md
		
		# Or use VS Code to open
		code README.md
		
		# View file content
		cat README.md
	7. Rename :
		# Rename a file
		git mv old-name.md new-name.md
		
		# Move file to another folder
		git mv README.md concepts/README.md
		
		# Commit the rename/move
		git commit -m "Rename and move files"
	8. Delete 
		# Delete a single file
		git rm scripts/old-script.sh
		
		# Delete a folder
		git rm -r demos/old-demo/
		
		# Remove file from git tracking but KEEP it locally
		git rm --cached secrets.txt
		
		# Commit the deletion
		git commit -m "Remove old scripts"
		
	9. Branch operations 
	# List all branches
	git branch
	
	# Create a new branch
	git branch feature/add-demos
	
	# Switch to a branch
	git checkout feature/add-demos
	
	# Create and switch in one step
	git checkout -b feature/add-demos
	
	# Push new branch to GitHub
	git push origin feature/add-demos
	
	# Merge branch into main
	git checkout main
	git merge feature/add-demos
	
	# Delete a branch locally
	git branch -d feature/add-demos
	
	# Delete branch on GitHub
	git push origin --delete feature/add-demos
	
	10. Check history and differences 
		# View commit history
		git log
		
		# Short one-line log
		git log --oneline
		
		# See changes in a file
		git diff README.md
		
		# See staged changes
		git diff --staged
		
		# See specific commit
		git show abc1234
		
	11. Undo and Revert 
		# Undo unstaged changes in a file
		git checkout -- README.md
		
		# Unstage a file (keep changes)
		git reset HEAD README.md
		
		# Undo last commit (keep changes)
		git reset --soft HEAD~1
		
		# Undo last commit (discard changes) ⚠️
		git reset --hard HEAD~1
		
		# Revert a specific commit safely
		git revert abc1234
		
	12. Examples :
	# Step 1 - Pull latest
	git pull origin main
	
	# Step 2 - Create a branch
	git checkout -b feature/add-terraform-demo
	
	# Step 3 - Make your changes
	mkdir -p demos/03-terraform-demo
	touch demos/03-terraform-demo/main.tf
	code demos/03-terraform-demo/main.tf
	
	# Step 4 - Stage changes
	git add .
	
	# Step 5 - Commit
	git commit -m "feat: add terraform demo"
	
	# Step 6 - Push to GitHub
	git push origin feature/add-terraform-demo
	
